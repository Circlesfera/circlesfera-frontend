# ========================================
# CircleSfera Backend - NPM Configuration
# ========================================

# === Resolución de Dependencias ===
# Ignorar conflictos de peer dependencies (comportamiento NPM 6)
legacy-peer-deps=true

# === Performance y Caché ===
# Preferir caché offline cuando sea posible
prefer-offline=true

# Configuración de reintentos de descarga
fetch-retries=3
fetch-retry-mintimeout=10000
fetch-retry-maxtimeout=60000

# === Seguridad ===
# Ejecutar auditoría automáticamente
audit=true

# Nivel de auditoría (low, moderate, high, critical)
audit-level=moderate

# === Logs y Output ===
# Nivel de logging (silent, error, warn, notice, http, timing, info, verbose, silly)
loglevel=warn

# Progress bar durante instalación
progress=true

# === Engine y Versiones ===
# Respetar versiones de engines en package.json
engine-strict=true

# === Lockfile ===
# Generar y usar package-lock.json
package-lock=true

# === Instalación de Paquetes ===
# Guardar versiones exactas en package.json (sin ^)
save-exact=false

# Prefijo para versiones guardadas (^ o ~)
save-prefix=^

# === Flags Opcionales ===
# Instalar solo dependencias de producción con --production
# production=false (por defecto)

# Verificar integridad de paquetes
# package-lock-only=false (por defecto)
