<svg width="200" height="200" viewBox="0 0 200 200" xmlns="http://www.w3.org/2000/svg">
  <!-- Fondo circular degradado -->
  <defs>
    <linearGradient id="bgGradient" x1="0%" y1="0%" x2="100%" y2="100%">
      <stop offset="0%" style="stop-color:#3b82f6;stop-opacity:1" />
      <stop offset="100%" style="stop-color:#8b5cf6;stop-opacity:1" />
    </linearGradient>
  </defs>

  <!-- Círculo de fondo -->
  <circle cx="100" cy="100" r="100" fill="url(#bgGradient)"/>

  <!-- Silueta de persona (blanco) -->
  <!-- Cabeza -->
  <circle cx="100" cy="75" r="30" fill="white" opacity="0.9"/>

  <!-- Cuerpo (forma de trapecio redondeado) -->
  <path d="M 100 105 Q 70 105 60 130 L 60 200 L 140 200 L 140 130 Q 130 105 100 105 Z"
        fill="white" opacity="0.9"/>
</svg>

